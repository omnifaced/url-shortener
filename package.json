{
	"name": "url-shortener",
	"description": "Service for shortening long links",
	"version": "2.1.0",
	"author": "omnifaced",
	"license": "SEE LICENSE",
	"type": "module",
	"scripts": {
		"format": "biome format --write",
		"lint": "biome lint --write",
		"type:check": "tsc --project ./tsconfig.json",
		"start": "pnpm type:check && tsx ./src/index.ts",
		"dev": "pnpm type:check && tsx watch ./src/index.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"gen:types:config": "json2ts --additionalProperties false -i config/schemas/config.yaml -o src/shared/config/config.d.ts",
		"test": "node --import tsx --test --experimental-test-coverage \"src/**/*.test.ts\"",
		"test:watch": "node --import tsx --test --watch \"src/**/*.test.ts\""
	},
	"dependencies": {
		"@hono/node-server": "^2.0.2",
		"@hono/swagger-ui": "^0.6.1",
		"@hono/zod-openapi": "^1.4.0",
		"@hono/zod-validator": "^0.8.0",
		"ajv": "^8.20.0",
		"consola": "^3.4.2",
		"cron": "^4.4.0",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.18",
		"hono-rate-limiter": "^0.5.3",
		"lru-cache": "^11.3.6",
		"postgres": "^3.4.9",
		"prom-client": "^15.1.3",
		"qr": "^0.6.0",
		"redis": "^5.12.1",
		"ua-parser-js": "^2.0.10",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/node": "^25.7.0",
		"drizzle-kit": "^0.31.10",
		"json-schema-to-typescript": "^15.0.4",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	}
}
